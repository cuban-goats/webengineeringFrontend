---
import "../styles/baseLayout.css";
import ThemeToggle from "../components/ThemeToggle.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ranq</title>
    <script is:inline>
      const t = localStorage.getItem("theme");
      if (t) document.documentElement.setAttribute("data-theme", t);
    </script>
  </head>
  <body>
    <header>
      <ThemeToggle />
    </header>
    <main>
      <div class="scroll-wrapper">
        <slot />
      </div>
    </main>
    <footer>
      <nav class="floating-nav">
        <a href="/start" aria-label="Feed">Feed</a>
        <a href="/search" aria-label="Search">Search</a>
        <a href="/create" aria-label="Create">Create</a>
        <a href="/settings" aria-label="Settings">Settings</a>
        <a href="/login" aria-label="Logout">Logout</a>
      </nav>
    </footer>
  </body>
</html>
