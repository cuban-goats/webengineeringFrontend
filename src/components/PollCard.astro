---
import "../styles/poll-card.css";

interface Option {
  id: string;
  option: string;
  votes: number;
}

interface Props {
  poll: {
    id: string;
    question: string;
    created_by: string;
    options: Option[];
  };
}

const { poll } = Astro.props;
const totalVotes = poll.options.reduce((sum, o) => sum + o.votes, 0);
---

<a class="poll-card" href={`/poll/${poll.id}`}>
  <p class="poll-question">{poll.question}</p>
  <ul class="poll-options">
    {
      poll.options.map((opt) => {
        const pct = totalVotes > 0 ? Math.round((opt.votes / totalVotes) * 100) : 0;
        return (
          <li class="poll-option">
            <div class="poll-option-bar" style={`width: ${pct}%`} />
            <span class="poll-option-label">{opt.option}</span>
            <span class="poll-option-pct">{pct}%</span>
          </li>
        );
      })
    }
  </ul>
  <span class="poll-meta">{totalVotes} vote{totalVotes !== 1 ? "s" : ""}</span>
</a>
