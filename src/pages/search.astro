---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import "../styles/searchPage.css";

const mockPosts = [
  {
    id: 1,
    username: "alice",
    avatar: "🐱",
    content: "Just finished my first Astro project — loving how fast it is!",
    likes: 24,
    comments: 5,
    timestamp: "2m ago",
  },
  {
    id: 2,
    username: "bob_dev",
    avatar: "🐶",
    content: "Hot take: monospace fonts make every UI look 10x better.",
    likes: 61,
    comments: 12,
    timestamp: "14m ago",
  },
  {
    id: 3,
    username: "carol",
    avatar: "🦊",
    content:
      "Anyone else spending their weekend debugging CSS instead of touching grass?",
    likes: 108,
    comments: 33,
    timestamp: "1h ago",
  },
  {
    id: 4,
    username: "dan42",
    avatar: "🐻",
    content: "Reminder that done is better than perfect. Ship the thing.",
    likes: 77,
    comments: 8,
    timestamp: "3h ago",
  },
  {
    id: 5,
    username: "eve.codes",
    avatar: "🐼",
    content:
      "New blog post: why I switched from React to Astro for all my side projects.",
    likes: 45,
    comments: 19,
    timestamp: "5h ago",
  },
];
---

<BaseLayout>
  <div class="search-page">
    <div class="search-wrapper">
      <input
        id="search-input"
        type="text"
        placeholder="Search posts or users..."
        autocomplete="off"
      />
    </div>

    <p id="no-results" class="no-results hidden">No results found.</p>

    <div id="post-list" class="post-list">
      {
        mockPosts.map((post) => (
          <div
            class="post-wrapper hidden"
            data-username={post.username}
            data-content={post.content}
          >
            <PostCard post={post} />
          </div>
        ))
      }
    </div>
  </div>
</BaseLayout>

<script is:inline>
  const input = document.getElementById("search-input");
  const noResults = document.getElementById("no-results");
  const postWrappers = document.querySelectorAll(".post-wrapper");

  input.addEventListener("input", function () {
    const query = input.value.toLowerCase();

    if (query === "") {
      for (let i = 0; i < postWrappers.length; i++) {
        postWrappers[i].classList.add("hidden");
      }
      noResults.classList.add("hidden");
      return;
    }

    let foundAny = false;

    for (let i = 0; i < postWrappers.length; i++) {
      const wrapper = postWrappers[i];
      const username = wrapper.dataset.username.toLowerCase();
      const content = wrapper.dataset.content.toLowerCase();

      if (username.includes(query) || content.includes(query)) {
        wrapper.classList.remove("hidden");
        foundAny = true;
      } else {
        wrapper.classList.add("hidden");
      }
    }

    if (foundAny) {
      noResults.classList.add("hidden");
    } else {
      noResults.classList.remove("hidden");
    }
  });
</script>
