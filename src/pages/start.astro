---
import BaseLayout from '../layouts/BaseLayout.astro'
import PostCard from '../components/PostCard.astro'
import '../styles/startPage.css';

const mockPosts = [
    {
        id: 1,
        username: "alice",
        avatar: "🐱",
        content: "Just finished my first Astro project — loving how fast it is!",
        likes: 24,
        comments: 5,
        timestamp: "2m ago",
    },
    {
        id: 2,
        username: "bob_dev",
        avatar: "🐶",
        content: "Hot take: monospace fonts make every UI look 10x better.",
        likes: 61,
        comments: 12,
        timestamp: "14m ago",
    },
    {
        id: 3,
        username: "carol",
        avatar: "🦊",
        content: "Anyone else spending their weekend debugging CSS instead of touching grass?",
        likes: 108,
        comments: 33,
        timestamp: "1h ago",
    },
    {
        id: 4,
        username: "dan42",
        avatar: "🐻",
        content: "Reminder that done is better than perfect. Ship the thing.",
        likes: 77,
        comments: 8,
        timestamp: "3h ago",
    },
    {
        id: 5,
        username: "eve.codes",
        avatar: "🐼",
        content: "New blog post: why I switched from React to Astro for all my side projects.",
        likes: 45,
        comments: 19,
        timestamp: "5h ago",
    },
];
---

<BaseLayout>
    <div class="feed">
        {mockPosts.map((post) => (
            <PostCard post={post} />
        ))}
    </div>
</BaseLayout>

<style>
    .feed {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding-bottom: 5rem;
    }
</style>
