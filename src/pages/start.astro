---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/start.css";
import "../styles/poll-card.css";
---

<BaseLayout>
  <div class="page-header">
    <h1 class="page-title">Feed</h1>
  </div>
  <div class="filters" style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem;">
    <select id="filter-sort">
      <option value="newest">Newest</option>
      <option value="oldest">Oldest</option>
      <option value="popular">Most votes</option>
    </select>
    <label class="filter-voted">
      <input id="filter-voted" type="checkbox" />
      Voted
    </label>
  </div>
  <div id="feed" class="feed">
    <p class="feed-loading">loading...</p>
  </div>
</BaseLayout>

<script src="../scripts/feed.ts"></script>
