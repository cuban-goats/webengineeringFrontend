---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <div class="not-found">
    <p class="not-found-code">404</p>
    <p class="not-found-msg">page not found.</p>
    <a href="/feed">go home</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 60vh;
    text-align: center;
  }

  .not-found-code {
    font-size: 4rem;
    font-weight: bold;
    margin: 0;
    opacity: 0.15;
  }

  .not-found-msg {
    font-size: var(--font-size-md);
    margin: 0;
    opacity: 0.5;
  }

  a {
    margin-top: 1rem;
    font-size: var(--font-size-md);
  }
</style>
